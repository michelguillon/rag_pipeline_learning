# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets / environment
.env
.env.*
*.key
# ...but the template IS committed (shows required vars, no real key)
!.env.example

# Vector store — large, machine-specific, regenerated by ingest.py
chroma_db/
*.sqlite3

# Real CVs — never committed. The fake sample CV IS committed (the example).
data/*.docx
data/*.pdf
data/*.txt
!data/.gitkeep
!data/sample_cv.docx

# outputs/ is tracked intentionally — holds the sample CV's example artifacts.
# Phase 2 validation outputs are NOT — they contain real CV text from the
# private cv2/cv3 documents the cross-document run is built on.
outputs/phase2_validation/
# analyse.py --trace dumps the raw Mistral prompt + response for debugging.
# Useful locally, noisy in git — and may incidentally capture document text.
outputs/*_trace.txt

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
